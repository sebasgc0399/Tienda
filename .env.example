# Copy to .env.local and fill in your own values (never commit .env.local).
# Where each value comes from: docs/guides/setup-desde-cero.md, section 6.

# Public: safe in the client bundle, protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Digits-only international format, no "+", spaces or dashes (e.g. 573001234567).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Server-only. BYPASSES RLS. Never prefix with NEXT_PUBLIC_ (CLAUDE.md section 9).
SUPABASE_SERVICE_ROLE_KEY=
